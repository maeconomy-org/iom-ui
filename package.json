    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22",
    "@types/papaparse": "^5.3.16",
    "@types/react": "^19.2.9",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.29.1",
    "@typescript-eslint/parser": "^8.29.1",
    "@vitejs/plugin-react": "^5.1.2",
