# UI Local Development Environment Variables
# Copy this file to .env.local for local development
# All variables are runtime-configurable (no rebuild needed)

# =============================================================================
# REQUIRED VARIABLES (must be configured)
# =============================================================================

# Environment Configuration
NODE_ENV="development"

# API Configuration (REQUIRED)
AUTH_REFRESH_API_URL="https://example.com:6443"
AUTH_API_URL="https://example.com:7443"
NODE_API_URL="https://example.com:9443"
REGISTRY_API_URL="https://example.com:8443"

# HERE Maps API Key (REQUIRED for map features)
HERE_API_KEY=your-here-api-key

# Redis Configuration (REQUIRED - use local Redis)
REDIS_URL="redis://localhost:6379"
REDIS_PASSWORD=your-secure-redis-password

# =============================================================================
# DEVELOPMENT DEFAULTS (recommended for local dev)
# =============================================================================

# Logging (simplified - only LOG_LEVEL needed)
LOG_LEVEL=debug                       # debug, info, warn, error

# Sentry Configuration (optional for development)
# SENTRY_DSN=https://your-key@o123.ingest.de.sentry.io/456
# SENTRY_ORG=your-organization-slug
# SENTRY_PROJECT=your-project-name-dev
# SENTRY_ENABLED=false
# SENTRY_RELEASE=dev